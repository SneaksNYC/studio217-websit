# Studio217 Environment Configuration

# Database Configuration
# For development, SQLite will be used automatically
# For production, set one of these:
# DATABASE_URL=postgresql://user:pass@localhost/studio217
# MONGODB_URI=mongodb://localhost:27017/studio217

# SQLite Configuration (Development)
SQLITE_PATH=./studio217.db

# JWT Secret for Authentication
# Generate a secure random string for production
JWT_SECRET=your-super-secure-jwt-secret-key-here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Node Environment
NODE_ENV=development